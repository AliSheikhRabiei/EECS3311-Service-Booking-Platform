# Copy this file to .env and fill in values for local development.
# Never commit a real .env file to Git.

# Database connection
DB_URL=jdbc:postgresql://localhost:5432/booking_platform
DB_USER=postgres
DB_PASSWORD=postgres

# HTTP server port
PORT=8080

# Default admin account created on first startup
ADMIN_EMAIL=admin@platform.com
ADMIN_PASSWORD=admin123
