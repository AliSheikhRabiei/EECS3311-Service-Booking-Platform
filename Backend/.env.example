# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub — it is in .gitignore.

# Database connection (used when running locally without Docker)
DB_URL=jdbc:postgresql://localhost:5432/booking_platform
DB_USER=postgres
DB_PASSWORD=postgres

# HTTP server port
PORT=8080

# Default admin account — created automatically on first startup
ADMIN_EMAIL=admin@platform.com
ADMIN_PASSWORD=admin123

# AI Customer Assistant — required for the chatbot to work
# Get your key at: https://platform.openai.com/api-keys  or your provider's dashboard
# The backend reads this in ChatHandler.java via System.getenv("OPENAI_API_KEY")
# If not set, POST /chat returns 500 "AI service is not configured"
OPENAI_API_KEY=sk-your-real-key-here
